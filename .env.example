# Acad Platform — Environment Variables
# Copy this file to .env and fill in your values

# --- Cloud mode (Phase 2) — set both to enable Supabase auth + sync ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Staging banner + robots noindex behaviour
VITE_APP_ENV=staging

# --- Local-only AI (omit when using Supabase edge functions) ---
# VITE_DEEPSEEK_API_KEY=
# VITE_ANTHROPIC_API_KEY=

# Firebase (optional future — not wired in app yet)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_DATABASE_URL=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_APP_ID=

# Server-only (seed script + edge functions — never commit)
# OPENAI_API_KEY=          # Supabase edge secret (preferred name)
# OPENAI_API_KEY_FOR_ACAD= # alternate name also supported by edge functions
# SUPABASE_SERVICE_ROLE_KEY=
